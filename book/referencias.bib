@misc{proenza2025,
   abstract = {High-intensity ultrasound (HIU) is a novel and emerging technology that has been used as an adjuvant in bioprocesses. Water kefir is a fermented beverage based on a sucrose solution inoculated with microorganisms present in kefir grains. However, the consequences of using this technology in the production of water kefir are currently unknown. Therefore, the objective of this work was to investigate the effect of HIU on the metabolites and functional properties of water kefir. Five treatments were prepared, in which 70 g / L of piloncillo solution was ultrasonicated at 20 and 34 W / cm2 for 15 and 60 seconds, in addition to the control. The solution was then inoculated with 9 % (w/v) kefir grains and fermented for 168 h at 25 °C under atmospheric conditions without stirring. The results showed that UIA favored the generation of specific metabolites. The 20 W / cm2 for 60 s treatment had the significantly (p < 0.05) highest increase in dry biomass, 37.10 ± 0.49 g / L. In parallel, this treatment presented the highest glucose concentration significantly (p < 0.05) at 48 h of fermentation, 16.8 ± 1.0 g / L. However, the 34 W / cm2 for 15 s treatment significantly had the highest (p < 0.05) antioxidant activity at the end of fermentation, 94.9 ± 0.05 %. The wet biomass values ​​during the fermentation kinetics were subjected to the Logistic mathematical model presenting R2 = 0.969 - 0.997. In conclusion, the UIA favored the generation of dry biomass, specific metabolites and functional properties in the water kefir beverage.},   
   author = {Proenza Delgado Y and J. C. Rodríguez Figueroa},
   title = {Efecto del ultrasonido de intensidad alta y la fermentación sobre metabolitos específicos y propiedades funcionales del kéfir de agua},
   year = {2025}
}